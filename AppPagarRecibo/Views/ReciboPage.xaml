<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppPagarRecibo.Views.ReciboPage"
             Title="Recibo de Pago"
             BackgroundColor="#F5F5F5"
             Shell.BackButtonBehavior="{x:Null}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12">

            <!-- Header éxito -->
            <Frame BackgroundColor="#2E7D32" CornerRadius="10" Padding="15" HasShadow="True">
                <VerticalStackLayout HorizontalOptions="Center" Spacing="5">
                    <Label Text="✅" FontSize="40" HorizontalOptions="Center"/>
                    <Label Text="PAGO EXITOSO" FontSize="20" TextColor="White" FontAttributes="Bold" HorizontalOptions="Center"/>
                    <Label Text="{Binding Codigo, StringFormat='Código: {0}'}" FontSize="13" TextColor="#A5D6A7" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Recibo -->
            <Frame BackgroundColor="White" CornerRadius="10" Padding="18" HasShadow="True">
                <VerticalStackLayout Spacing="6">
                    <Label Text="RECIBO DE PAGO DE INSCRIPCIÓN" FontSize="15" FontAttributes="Bold"
                           TextColor="#FF4682B4" HorizontalOptions="Center"/>
                    <Label Text="INSTITUTO TECNOLÓGICO SUPERIOR DE MONCLOVA" FontSize="11"
                           TextColor="#666" HorizontalOptions="Center"/>
                    <BoxView HeightRequest="2" Color="#FF4682B4" Margin="0,5"/>

                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                          ColumnSpacing="12" RowSpacing="6">
                        <Label Grid.Row="0" Grid.Column="0" Text="Referencia:" FontAttributes="Bold" FontSize="13" TextColor="#555"/>
                        <Label Grid.Row="0" Grid.Column="1" Text="{Binding Referencia}" FontSize="13" TextColor="#333"/>

                        <Label Grid.Row="1" Grid.Column="0" Text="Total pagado:" FontAttributes="Bold" FontSize="13" TextColor="#555"/>
                        <Label Grid.Row="1" Grid.Column="1" Text="{Binding TotalPagado, StringFormat='${0:N2} MXN'}"
                               FontSize="13" TextColor="#2E7D32" FontAttributes="Bold"/>

                        <Label Grid.Row="2" Grid.Column="0" Text="Matrícula:" FontAttributes="Bold" FontSize="13" TextColor="#555"/>
                        <Label Grid.Row="2" Grid.Column="1" Text="{Binding Matricula}" FontSize="13" TextColor="#333"/>

                        <Label Grid.Row="3" Grid.Column="0" Text="Alumno(a):" FontAttributes="Bold" FontSize="13" TextColor="#555"/>
                        <Label Grid.Row="3" Grid.Column="1" Text="{Binding NombreAlumno}" FontSize="13" TextColor="#333"/>

                        <Label Grid.Row="4" Grid.Column="0" Text="Concepto:" FontAttributes="Bold" FontSize="13" TextColor="#555"/>
                        <Label Grid.Row="4" Grid.Column="1" Text="{Binding Concepto}" FontSize="12" TextColor="#333"/>

                        <Label Grid.Row="5" Grid.Column="0" Text="Periodo:" FontAttributes="Bold" FontSize="13" TextColor="#555"/>
                        <Label Grid.Row="5" Grid.Column="1" Text="{Binding Periodo}" FontSize="13" TextColor="#333"/>

                        <Label Grid.Row="6" Grid.Column="0" Text="Carrera:" FontAttributes="Bold" FontSize="13" TextColor="#555"/>
                        <Label Grid.Row="6" Grid.Column="1" Text="{Binding Carrera}" FontSize="13" TextColor="#333"/>

                        <Label Grid.Row="7" Grid.Column="0" Text="Semestre:" FontAttributes="Bold" FontSize="13" TextColor="#555"/>
                        <Label Grid.Row="7" Grid.Column="1" Text="{Binding Semestre}" FontSize="13" TextColor="#333"/>
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!-- Detalles del pago según tipo -->
            <Frame BackgroundColor="White" CornerRadius="10" Padding="18" HasShadow="True">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Detalle del Pago" FontSize="15" FontAttributes="Bold" TextColor="#FF4682B4"/>
                    <BoxView HeightRequest="1" Color="#E0E0E0"/>

                    <!-- Si fue con tarjeta -->
                    <VerticalStackLayout Spacing="4" IsVisible="{Binding FueConTarjeta}">
                        <Label Text="Método: Tarjeta de Débito" FontSize="13" TextColor="#555"/>
                        <Label Text="{Binding TarjetaEnmascarada, StringFormat='Tarjeta: {0}'}" FontSize="14" FontAttributes="Bold" TextColor="#333"/>
                        <Label Text="{Binding BancoEmisor, StringFormat='Banco: {0}'}" FontSize="13" TextColor="#555"/>
                    </VerticalStackLayout>

                    <!-- Si fue con SPEI -->
                    <VerticalStackLayout Spacing="4" IsVisible="{Binding FueConSPEI}">
                        <Label Text="Método: Transferencia SPEI" FontSize="13" TextColor="#555"/>
                        <Label Text="{Binding BancoReceptor, StringFormat='Banco receptor: {0}'}" FontSize="13" TextColor="#333"/>
                        <Label Text="{Binding CuentaDeposito, StringFormat='Cuenta: {0}'}" FontSize="13" TextColor="#333"/>
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1" Color="#E0E0E0" Margin="0,4"/>
                    <Label Text="{Binding FechaMovimiento, StringFormat='Fecha de pago: {0:dd/MM/yyyy HH:mm}'}" FontSize="13" TextColor="#555"/>
                    <Label Text="{Binding FechaVencimiento, StringFormat='Fecha vencimiento: {0:dd/MM/yyyy}'}" FontSize="13" TextColor="#555"/>
                </VerticalStackLayout>
            </Frame>

            <Frame BackgroundColor="#E8F5E9" CornerRadius="8" Padding="10" HasShadow="False">
                <Label Text="Una vez realizado el pago, no habrá devoluciones."
                       FontSize="12" TextColor="#2E7D32" HorizontalTextAlignment="Center" FontAttributes="Italic"/>
            </Frame>

            <Button Text="Volver al Inicio" BackgroundColor="#FF4682B4" TextColor="White"
                    FontAttributes="Bold" CornerRadius="8" HeightRequest="48" FontSize="16"
                    Clicked="VolverInicio_Clicked"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
