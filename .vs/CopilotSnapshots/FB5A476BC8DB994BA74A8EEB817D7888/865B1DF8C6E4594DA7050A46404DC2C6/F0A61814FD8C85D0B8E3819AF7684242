<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:AppPagarRecibo.Behaviors"
             x:Class="AppPagarRecibo.Views.PagoPage"
             Title="Pagar Inscripción"
             BackgroundColor="#F5F5F5">

    <Grid>

        <ScrollView>
            <VerticalStackLayout Padding="20" Spacing="12">

                <Frame BackgroundColor="#FF4682B4" CornerRadius="10" Padding="15" HasShadow="True">
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="3">
                        <Label Text="Total a pagar" FontSize="14" TextColor="#FFB0E0E6" HorizontalOptions="Center"/>
                        <Label Text="{Binding MontoTotal, StringFormat='${0:N2} MXN'}" FontSize="28" TextColor="White"
                               FontAttributes="Bold" HorizontalOptions="Center"/>
                        <Label Text="{Binding Referencia, StringFormat='Ref: {0}'}" FontSize="12" TextColor="#FFB0E0E6" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Frame>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                    <Button Grid.Column="0" Text="💳 Tarjeta Débito" Command="{Binding SeleccionarTarjetaCommand}"
                            CornerRadius="8" FontSize="13" FontAttributes="Bold">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button" Binding="{Binding PagoConTarjeta}" Value="True">
                                <Setter Property="BackgroundColor" Value="#FF4682B4"/>
                                <Setter Property="TextColor" Value="White"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Button" Binding="{Binding PagoConTarjeta}" Value="False">
                                <Setter Property="BackgroundColor" Value="#E0E0E0"/>
                                <Setter Property="TextColor" Value="#333"/>
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>
                    <Button Grid.Column="1" Text="🏦 Transferencia SPEI" Command="{Binding SeleccionarSPEICommand}"
                            CornerRadius="8" FontSize="13" FontAttributes="Bold">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button" Binding="{Binding PagoConSPEI}" Value="True">
                                <Setter Property="BackgroundColor" Value="#FF4682B4"/>
                                <Setter Property="TextColor" Value="White"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Button" Binding="{Binding PagoConSPEI}" Value="False">
                                <Setter Property="BackgroundColor" Value="#E0E0E0"/>
                                <Setter Property="TextColor" Value="#333"/>
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>
                </Grid>

                <Frame BackgroundColor="White" CornerRadius="10" Padding="18" HasShadow="True"
                       IsVisible="{Binding PagoConTarjeta}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Pago con Tarjeta de Débito" FontSize="16" FontAttributes="Bold" TextColor="#FF4682B4"/>
                        <BoxView HeightRequest="1" Color="#E0E0E0"/>

                        <Label Text="Titular de la tarjeta" FontSize="13" TextColor="#555" FontAttributes="Bold"/>
                        <Entry Placeholder="Nombre como aparece en la tarjeta" Text="{Binding TitularTarjeta}"
                               Keyboard="Text" MaxLength="50" BackgroundColor="#F9F9F9" TextColor="#333" PlaceholderColor="#999"/>

                        <Label Text="Número de tarjeta" FontSize="13" TextColor="#555" FontAttributes="Bold"/>
                        <Entry Placeholder="1234 5678 9012 3456" Text="{Binding NumeroTarjeta}"
                               Keyboard="Numeric" MaxLength="19" BackgroundColor="#F9F9F9" TextColor="#333" PlaceholderColor="#999"/>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <VerticalStackLayout Grid.Column="0" Spacing="4">
                                <Label Text="Vencimiento" FontSize="13" TextColor="#555" FontAttributes="Bold"/>
                                <Entry Placeholder="MM/AA" Text="{Binding FechaVencimientoTarjeta}"
                                       Keyboard="Text" MaxLength="5" BackgroundColor="#F9F9F9" TextColor="#333" PlaceholderColor="#999"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                <Label Text="CVV" FontSize="13" TextColor="#555" FontAttributes="Bold"/>
                                <Entry Placeholder="123" Text="{Binding CVV}" IsPassword="True"
                                       Keyboard="Numeric" MaxLength="3" BackgroundColor="#F9F9F9" TextColor="#333" PlaceholderColor="#999"/>
                            </VerticalStackLayout>
                        </Grid>

                        <Label Text="Banco emisor" FontSize="13" TextColor="#555" FontAttributes="Bold"/>
                        <Picker Title="Selecciona tu banco" ItemsSource="{Binding BancosDisponibles}"
                                SelectedItem="{Binding BancoEmisor}"/>

                        <Button Text="Pagar" Command="{Binding PagarConTarjetaCommand}"
                                BackgroundColor="#2E7D32" TextColor="White" FontAttributes="Bold"
                                CornerRadius="8" HeightRequest="48" FontSize="16"/>
                    </VerticalStackLayout>
                </Frame>

                <Frame BackgroundColor="White" CornerRadius="10" Padding="18" HasShadow="True"
                       IsVisible="{Binding PagoConSPEI}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Pago con Transferencia SPEI" FontSize="16" FontAttributes="Bold" TextColor="#FF4682B4"/>
                        <BoxView HeightRequest="1" Color="#E0E0E0"/>

                        <Label Text="CLABE Interbancaria" FontSize="12" TextColor="#888"/>
                        <Frame BackgroundColor="#F5F5F5" CornerRadius="6" Padding="10" HasShadow="False">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="{Binding CLABE}" FontSize="16" FontAttributes="Bold" TextColor="#333" VerticalOptions="Center"/>
                                <Button Grid.Column="1" Text="Copiar" Command="{Binding CopiarCLABECommand}"
                                        BackgroundColor="#FF4682B4" TextColor="White" CornerRadius="6" FontSize="11" HeightRequest="35" Padding="10,0"/>
                            </Grid>
                        </Frame>

                        <Label Text="Referencia de pago" FontSize="12" TextColor="#888"/>
                        <Frame BackgroundColor="#F5F5F5" CornerRadius="6" Padding="10" HasShadow="False">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="{Binding Referencia}" FontSize="16" FontAttributes="Bold" TextColor="#333" VerticalOptions="Center"/>
                                <Button Grid.Column="1" Text="Copiar" Command="{Binding CopiarReferenciaCommand}"
                                        BackgroundColor="#FF4682B4" TextColor="White" CornerRadius="6" FontSize="11" HeightRequest="35" Padding="10,0"/>
                            </Grid>
                        </Frame>

                        <Label Text="Concepto (poner en tu transferencia)" FontSize="12" TextColor="#888"/>
                        <Frame BackgroundColor="#F5F5F5" CornerRadius="6" Padding="10" HasShadow="False">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="{Binding ConceptoSPEI}" FontSize="13" FontAttributes="Bold" TextColor="#333" VerticalOptions="Center"/>
                                <Button Grid.Column="1" Text="Copiar" Command="{Binding CopiarConceptoCommand}"
                                        BackgroundColor="#FF4682B4" TextColor="White" CornerRadius="6" FontSize="11" HeightRequest="35" Padding="10,0"/>
                            </Grid>
                        </Frame>

                        <Label Text="{Binding BancoReceptor, StringFormat='Banco receptor: {0}'}" FontSize="13" TextColor="#555"/>
                        <Label Text="{Binding FechaVencimiento, StringFormat='Fecha límite: {0:dd/MM/yyyy}'}" FontSize="13" TextColor="#C62828" FontAttributes="Bold"/>

                        <Label Text="Instrucciones:" FontSize="13" FontAttributes="Bold" TextColor="#555"/>
                        <Label Text="{Binding Instrucciones}" FontSize="12" TextColor="#666"/>

                        <Frame BackgroundColor="#FFF3E0" CornerRadius="6" Padding="8" HasShadow="False">
                            <Label Text="*Si pagas después de las 9pm se tomará el pago hasta el día siguiente"
                                   FontSize="11" TextColor="#E65100" FontAttributes="Italic"/>
                        </Frame>

                        <Button Text="Ya realicé mi pago" Command="{Binding ConfirmarSPEICommand}"
                                BackgroundColor="#2E7D32" TextColor="White" FontAttributes="Bold"
                                CornerRadius="8" HeightRequest="48" FontSize="16"/>
                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>

        <Frame BackgroundColor="White" CornerRadius="10" Padding="25" HasShadow="True"
               HorizontalOptions="Center" VerticalOptions="Center"
               IsVisible="{Binding VerificandoPago}">
            <VerticalStackLayout Spacing="15" HorizontalOptions="Center">
                <ActivityIndicator IsRunning="True" Color="#FF4682B4" HeightRequest="50" WidthRequest="50"/>
                <Label Text="{Binding MensajeEstado}" FontSize="16" TextColor="#FF4682B4"
                       FontAttributes="Bold" HorizontalOptions="Center"/>
            </VerticalStackLayout>
        </Frame>

    </Grid>
</ContentPage>